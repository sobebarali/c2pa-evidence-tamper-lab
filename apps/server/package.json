{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@c2pa-evidence-tamper-lab/api": "workspace:*",
    "@c2pa-evidence-tamper-lab/db": "workspace:*",
    "@c2pa-evidence-tamper-lab/env": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "dotenv": "catalog:",
    "evlog": "^2.19.2",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@c2pa-evidence-tamper-lab/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  }
}
